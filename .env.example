# Frontend-exposed Firebase config (safe for client-side apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Local-only fallback for direct Gemini calls (optional for local dev)
# Do not set this in production
VITE_GEMINI_API_KEY=

# Server-only Gemini key for Vercel function /api/gemini
# In Vercel, add this key in Project Settings -> Environment Variables
GEMINI_API_KEY=
